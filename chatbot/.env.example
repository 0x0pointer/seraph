# Talix Shield — chatbot environment variables
# Copy this file to .env and fill in your values.

# Base URL of your Talix Shield backend (no trailing slash)
TALIX_API_URL=http://localhost:8000

# Connection key from Dashboard → APIs → copy key
# Create a connection in the dashboard, then paste the ts_conn_... key here.
TALIX_CONNECTION_KEY=ts_conn_replace_with_your_key

# OpenAI API key
OPENAI_API_KEY=sk-replace_with_your_openai_key

# Model to use (optional — default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
